---
import { Image } from 'astro:assets';
import contactWaves from '../assets/contact-waves.png';

interface Props {
	contact: {
		title: string;
		text: string;
		phoneLabel: string;
		emailLabel: string;
		addressLabel: string;
		phone: string;
		email: string;
		address: string;
		cta: string;
	};
}

const { contact } = Astro.props;
const whatsappHref = `https://wa.me/${contact.phone.replace(/\D/g, '')}`;
---

<section id="consultation" class="contact">
	<div class="container contact-banner">
		<Image class="contact-art" src={contactWaves} alt="" width={768} height={512} loading="lazy" aria-hidden="true" />
		<div class="contact-copy">
			<h2>{contact.title}</h2>
			<p>{contact.text}</p>
		</div>

		<a class="button button-primary contact-cta" href={whatsappHref} target="_blank" rel="noreferrer">
			{contact.cta}
			<span aria-hidden="true">→</span>
		</a>

		<address class="contact-meta">
			<a href={`tel:${contact.phone.replace(/\s/g, '')}`}>{contact.phoneLabel}: {contact.phone}</a>
			<a href={`mailto:${contact.email}`}>{contact.emailLabel}: {contact.email}</a>
			<span>{contact.addressLabel}: {contact.address}</span>
		</address>
	</div>
</section>

<style>
	.contact {
		padding: 0 0 clamp(46px, 7vw, 78px);
		background: #ffffff;
	}

	.contact-banner {
		position: relative;
		overflow: hidden;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 36%);
		align-items: center;
		gap: clamp(24px, 6vw, 80px);
		border: 1px solid rgba(210, 228, 242, 0.92);
		border-radius: 8px;
		background: #ffffff;
		box-shadow: 0 18px 50px rgba(9, 44, 79, 0.07);
		padding: clamp(26px, 5vw, 48px);
	}

	.contact-art {
		position: absolute;
		inset: auto 0 0 auto;
		width: min(58%, 720px);
		height: 100%;
		object-fit: cover;
		object-position: right bottom;
		pointer-events: none;
	}

	.contact-copy {
		position: relative;
		z-index: 1;
		max-width: 560px;
	}

	h2 {
		max-width: 520px;
		margin: 0;
		color: var(--ink);
		font-size: clamp(1.55rem, 3vw, 2.45rem);
		line-height: 1.12;
		letter-spacing: 0;
	}

	p {
		max-width: 490px;
		margin: 16px 0 0;
		color: var(--muted);
		font-size: 0.98rem;
		line-height: 1.65;
	}

	.contact-cta {
		position: relative;
		z-index: 1;
		justify-self: start;
		min-width: min(280px, 100%);
	}

	.contact-cta span {
		font-size: 1.15rem;
		line-height: 1;
	}

	.contact-meta {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		white-space: nowrap;
	}

	@media (max-width: 760px) {
		.contact-banner {
			grid-template-columns: 1fr;
			padding-bottom: 96px;
		}

		.contact-art {
			width: 100%;
			height: 55%;
			opacity: 0.78;
		}

		.contact-cta {
			width: 100%;
		}
	}
</style>
