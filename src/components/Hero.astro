---
import { Image } from 'astro:assets';
import heroWaves from '../assets/hero-waves.png';
import TrustCards from './TrustCards.astro';

interface TrustCard {
	title: string;
	text: string;
	icon: string;
}

interface Props {
	hero: {
		eyebrow: string;
		title: string;
		description: string;
		primary: string;
		secondary: string;
		imageAlt: string;
	};
	trust: TrustCard[];
}

const { hero, trust } = Astro.props;
---

<section class="hero">
	<div class="hero-main">
		<div class="container hero-grid">
			<div class="hero-content">
				<p class="eyebrow">{hero.eyebrow}</p>
				<h1>{hero.title}</h1>
				<p class="hero-copy">{hero.description}</p>
				<div class="hero-actions">
					<a class="button button-primary" href="#contact">{hero.primary}</a>
					<a class="button button-secondary" href="#services">{hero.secondary}</a>
				</div>
			</div>

			<div class="hero-visual" aria-hidden="true">
				<Image src={heroWaves} alt={hero.imageAlt} width={720} height={480} loading="eager" />
			</div>
		</div>
	</div>
	<TrustCards items={trust} />
</section>

<style>
	.hero {
		display: grid;
		grid-template-rows: minmax(0, 1fr) var(--trust-band-height);
		height: calc(100svh - var(--header-height));
		overflow: hidden;
		background: #ffffff;
	}

	.hero-main {
		min-height: 0;
		padding-top: clamp(18px, 3.4vw, 44px);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.94fr) minmax(420px, 1.06fr);
		align-items: center;
		gap: clamp(26px, 4vw, 56px);
		height: 100%;
	}

	h1 {
		max-width: 720px;
		margin: 0;
		color: var(--ink);
		font-size: clamp(2rem, 3.7vw, 3.35rem);
		line-height: 1.04;
		letter-spacing: 0;
	}

	.hero-copy {
		max-width: 600px;
		margin: 18px 0 0;
		color: var(--muted);
		font-size: clamp(0.98rem, 1.5vw, 1.08rem);
		line-height: 1.58;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 24px;
	}

	.hero-visual {
		position: relative;
		height: 100%;
		min-height: 0;
		max-width: min(760px, 48vw);
		margin-left: auto;
		margin-right: calc((100vw - min(1160px, calc(100vw - 40px))) / -2);
		align-self: stretch;
	}

	.hero-visual img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: right bottom;
	}

	@media (max-width: 900px) {
		.hero {
			display: block;
			height: auto;
			min-height: auto;
			overflow: visible;
		}

		.hero-main {
			padding: 38px 0 clamp(44px, 8vw, 70px);
		}

		.hero-grid {
			grid-template-columns: 1fr;
			height: auto;
		}

		.hero-visual {
			display: none;
		}
	}

	@media (max-width: 620px) {
		h1 {
			font-size: clamp(2.35rem, 13vw, 3.5rem);
			line-height: 1.08;
		}

		.hero-actions {
			display: grid;
		}
	}
</style>
