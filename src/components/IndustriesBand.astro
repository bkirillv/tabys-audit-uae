---
import MaterialIcon from './MaterialIcon.astro';

interface Industry {
	title: string;
	icon: string;
}

interface Props {
	eyebrow: string;
	title: string;
	items: Industry[];
}

const { eyebrow, title, items } = Astro.props;
---

<section id="industries" class="industries">
	<div class="container">
		<div class="section-head">
			<p class="eyebrow">{eyebrow}</p>
			<h2>{title}</h2>
		</div>
		<div class="industry-list">
			{
				items.map((item) => (
					<span>
						<MaterialIcon name={item.icon} size={22} />
						{item.title}
					</span>
				))
			}
		</div>
	</div>
</section>

<style>
	.industries {
		padding: 0 0 clamp(44px, 7vw, 72px);
		background: #ffffff;
	}

	.section-head {
		margin-bottom: 28px;
		text-align: center;
	}

	h2 {
		margin: 0;
		color: var(--ink);
		font-size: clamp(1.65rem, 3vw, 2.45rem);
		line-height: 1.1;
		letter-spacing: 0;
	}

	.industry-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(112px, 1fr));
		gap: 18px;
	}

	.industry-list span {
		display: flex;
		min-height: 88px;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		gap: 10px;
		color: #243852;
		font-size: 0.82rem;
		font-weight: 800;
		line-height: 1.28;
		text-align: center;
	}

	.industry-list span :global(svg) {
		color: var(--blue);
	}

	@media (max-width: 960px) {
		.industry-list {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	@media (max-width: 520px) {
		.industry-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
