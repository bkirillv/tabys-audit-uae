---
interface Props {
	title: string;
	items: string[];
}

const { title, items } = Astro.props;
---

<section id="industries" class="industries">
	<div class="container industry-panel">
		<div class="industry-brand">
			<img src="/tabys-logo.png" alt="TABYS Audit Consulting" width="110" height="110" />
			<h2>{title}</h2>
		</div>
		<div class="industry-list">
			{
				items.map((item) => (
					<span>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
							<path d="M4 19V5h16v14H4zM8 9h8M8 13h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
						{item}
					</span>
				))
			}
		</div>
	</div>
</section>

<style>
	.industries {
		padding: 0 0 clamp(60px, 8vw, 96px);
	}

	.industry-panel {
		position: relative;
		overflow: hidden;
		display: grid;
		grid-template-columns: minmax(250px, 0.8fr) minmax(0, 1.2fr);
		gap: 34px;
		border-radius: 8px;
		background:
			linear-gradient(120deg, rgba(255, 122, 19, 0.96), transparent 18%),
			linear-gradient(130deg, #031932 0%, #062442 58%, #08345e 100%);
		padding: clamp(28px, 5vw, 48px);
		color: #ffffff;
	}

	.industry-panel::after {
		position: absolute;
		right: -90px;
		bottom: -128px;
		width: 360px;
		height: 220px;
		border-radius: 54% 46% 40% 60%;
		background: linear-gradient(135deg, #18bde8, #087fd0);
		content: "";
		transform: rotate(-18deg);
	}

	.industry-brand,
	.industry-list {
		position: relative;
		z-index: 1;
	}

	.industry-brand img {
		width: 104px;
		height: auto;
		margin-bottom: 20px;
		border-radius: 8px;
		background: #ffffff;
	}

	h2 {
		max-width: 480px;
		margin: 0;
		font-size: clamp(1.85rem, 3vw, 2.6rem);
		line-height: 1.1;
		letter-spacing: 0;
	}

	.industry-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
		align-content: center;
	}

	.industry-list span {
		display: flex;
		min-height: 48px;
		align-items: center;
		gap: 10px;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.06);
		padding: 12px 14px;
		font-weight: 800;
	}

	.industry-list svg {
		flex: 0 0 auto;
		color: #6dd9f2;
	}

	@media (max-width: 820px) {
		.industry-panel {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.industry-list {
			grid-template-columns: 1fr;
		}
	}
</style>
