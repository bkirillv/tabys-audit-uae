---
interface Step {
	title: string;
	text: string;
}

interface Props {
	eyebrow: string;
	title: string;
	steps: Step[];
}

const { eyebrow, title, steps } = Astro.props;
---

<section id="approach" class="process">
	<div class="container process-grid">
		<div>
			<p class="eyebrow">{eyebrow}</p>
			<h2 class="section-title">{title}</h2>
		</div>
		<div class="steps">
			{
				steps.map((step, index) => (
					<article>
						<span>{index + 1}</span>
						<div>
							<h3>{step.title}</h3>
							<p>{step.text}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.process {
		padding: clamp(62px, 9vw, 106px) 0;
	}

	.process-grid {
		display: grid;
		grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
		gap: clamp(30px, 6vw, 78px);
		align-items: start;
	}

	.steps {
		display: grid;
		gap: 16px;
	}

	article {
		display: grid;
		grid-template-columns: 54px 1fr;
		gap: 18px;
		border-bottom: 1px solid var(--line);
		padding: 0 0 22px;
	}

	article:last-child {
		border-bottom: 0;
		padding-bottom: 0;
	}

	span {
		display: grid;
		width: 54px;
		height: 54px;
		place-items: center;
		border-radius: 8px;
		background: var(--ink);
		color: #ffffff;
		font-weight: 900;
	}

	h3 {
		margin: 0 0 8px;
		font-size: 1.28rem;
	}

	p {
		margin: 0;
		color: var(--muted);
		line-height: 1.7;
	}

	@media (max-width: 800px) {
		.process-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
