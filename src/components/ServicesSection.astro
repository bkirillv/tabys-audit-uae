---
import MaterialIcon from './MaterialIcon.astro';

interface Service {
	title: string;
	points: string[];
	icon: string;
}

interface Props {
	eyebrow: string;
	title: string;
	items: Service[];
}

const { eyebrow, title, items } = Astro.props;
---

<section id="services" class="services">
	<div class="container">
		<div class="section-head">
			<p class="eyebrow">{eyebrow}</p>
			<h2 class="section-title">{title}</h2>
		</div>

		<div class="service-grid">
			{
				items.map((service, index) => (
					<article class="service-card">
						<div class="card-top">
							<div class="icon-box" aria-hidden="true">
								<MaterialIcon name={service.icon} />
							</div>
							<span>{String(index + 1).padStart(2, '0')}</span>
						</div>
						<h3>{service.title}</h3>
						<ul>
							{service.points.map((point) => (
								<li>{point}</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services {
		padding: clamp(56px, 8vw, 92px) 0;
		background: #ffffff;
	}

	.section-head {
		max-width: 780px;
		margin: 0 auto 34px;
		text-align: center;
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 18px;
	}

	.service-card {
		min-height: 300px;
		border: 1px solid rgba(220, 234, 246, 0.95);
		border-radius: 8px;
		background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
		padding: 22px;
		box-shadow: 0 12px 32px rgba(7, 26, 54, 0.05);
	}

	.card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.card-top span {
		color: rgba(18, 151, 223, 0.18);
		font-size: 2rem;
		font-weight: 900;
	}

	h3 {
		margin: 20px 0 14px;
		font-size: 1.02rem;
		line-height: 1.22;
	}

	ul {
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
		color: var(--muted);
		font-size: 0.9rem;
		line-height: 1.5;
		list-style: none;
	}

	li {
		position: relative;
		padding-left: 18px;
	}

	li::before {
		position: absolute;
		top: 0.68em;
		left: 0;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--orange);
		content: "";
	}

	@media (max-width: 1100px) {
		.service-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.service-grid {
			grid-template-columns: 1fr;
		}

		.service-card {
			min-height: auto;
		}
	}
</style>
