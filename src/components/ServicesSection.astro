---
interface Service {
	title: string;
	points: string[];
}

interface Props {
	eyebrow: string;
	title: string;
	items: Service[];
}

const { eyebrow, title, items } = Astro.props;
---

<section id="services" class="services">
	<div class="container">
		<div class="section-head">
			<p class="eyebrow">{eyebrow}</p>
			<h2 class="section-title">{title}</h2>
		</div>

		<div class="service-grid">
			{
				items.map((service, index) => (
					<article class="service-card">
						<div class="card-top">
							<div class="icon-box" aria-hidden="true">
								<svg viewBox="0 0 24 24" width="22" height="22" fill="none">
									<path d="M7 3h10a2 2 0 0 1 2 2v16l-4-2-3 2-3-2-4 2V5a2 2 0 0 1 2-2z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
									<path d={index % 2 === 0 ? 'M9 8h6M9 12h6M9 16h3' : 'M8 16l3-3 2 2 3-5'} stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
								</svg>
							</div>
							<span>{String(index + 1).padStart(2, '0')}</span>
						</div>
						<h3>{service.title}</h3>
						<ul>
							{service.points.map((point) => (
								<li>{point}</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services {
		padding: clamp(62px, 9vw, 106px) 0;
		background:
			linear-gradient(180deg, rgba(243, 249, 254, 0.8), rgba(255, 255, 255, 0.96)),
			linear-gradient(90deg, transparent, rgba(255, 122, 19, 0.05), transparent);
	}

	.section-head {
		max-width: 780px;
		margin: 0 auto 34px;
		text-align: center;
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.service-card {
		min-height: 310px;
		border: 1px solid rgba(220, 234, 246, 0.95);
		border-radius: 8px;
		background: #ffffff;
		padding: 24px;
		box-shadow: 0 16px 38px rgba(7, 26, 54, 0.06);
	}

	.card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.card-top span {
		color: rgba(18, 151, 223, 0.18);
		font-size: 2rem;
		font-weight: 900;
	}

	h3 {
		margin: 24px 0 14px;
		font-size: 1.22rem;
		line-height: 1.22;
	}

	ul {
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
		color: var(--muted);
		line-height: 1.55;
		list-style: none;
	}

	li {
		position: relative;
		padding-left: 18px;
	}

	li::before {
		position: absolute;
		top: 0.68em;
		left: 0;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--orange);
		content: "";
	}

	@media (max-width: 980px) {
		.service-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.service-grid {
			grid-template-columns: 1fr;
		}

		.service-card {
			min-height: auto;
		}
	}
</style>
