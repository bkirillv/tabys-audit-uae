---
import type { Locale } from '../i18n';

interface Props {
	lang: Locale;
	text: string;
}

const { lang, text } = Astro.props;
---

<footer class="site-footer">
	<div class="container footer-inner">
		<a href={`/${lang}/`} aria-label="TABYS home">
			<img src="/tabys-logo.png" alt="TABYS Audit Consulting" width="86" height="86" />
		</a>
		<p>{text}</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--line);
		background: #ffffff;
		padding: 24px 0;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
	}

	img {
		width: 86px;
		height: auto;
	}

	p {
		max-width: 560px;
		margin: 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.55;
		text-align: right;
	}

	@media (max-width: 560px) {
		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
		}

		p {
			text-align: left;
		}
	}
</style>
