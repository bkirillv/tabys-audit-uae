---
import { Image } from 'astro:assets';
import tabysLogoWide from '../assets/tabys-logo-wide.png';
import { locales, type Locale } from '../i18n';
import { withBase } from '../site';

interface Props {
	lang: Locale;
	ctaHref: string;
	common: {
		logoAlt: string;
		homeAria: string;
		primaryNavAria: string;
		languageSwitcherAria: string;
		localeLabels: Record<Locale, string>;
	};
	nav: {
		services: string;
		approach: string;
		industries: string;
		contact: string;
		cta: string;
	};
}

const { lang, nav, ctaHref, common } = Astro.props;
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href={withBase(`${lang}/`)} aria-label={common.homeAria}>
			<Image src={tabysLogoWide} alt={common.logoAlt} width={180} height={90} priority />
		</a>

		<nav class="nav" aria-label={common.primaryNavAria}>
			<a href="#services">{nav.services}</a>
			<a href="#approach">{nav.approach}</a>
			<a href="#industries">{nav.industries}</a>
			<a href="#contact">{nav.contact}</a>
		</nav>

		<div class="header-actions">
			<div class="locale-switcher" aria-label={common.languageSwitcherAria}>
				{
					locales.map((locale) => (
						<a class:list={['locale-link', { active: locale === lang }]} href={withBase(`${locale}/`)}>
							{common.localeLabels[locale]}
						</a>
					))
				}
			</div>
			<a class="button button-primary header-cta" href={ctaHref} target="_blank" rel="noreferrer">{nav.cta}</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(220, 234, 246, 0.78);
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(16px);
	}

	.header-inner {
		display: grid;
		min-height: 82px;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 28px;
	}

	.brand {
		display: flex;
		align-items: center;
	}

	.brand img {
		width: 142px;
		height: auto;
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(16px, 3vw, 34px);
		color: #31435d;
		font-size: 0.95rem;
		font-weight: 700;
	}

	.nav a {
		transition: color 180ms ease;
	}

	.nav a:hover {
		color: var(--blue-dark);
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.locale-switcher {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.locale-link {
		display: grid;
		min-width: 34px;
		height: 34px;
		place-items: center;
		border-radius: 8px;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 900;
		transition:
			background-color 180ms ease,
			color 180ms ease;
	}

	.locale-link:hover,
	.locale-link.active {
		background: rgba(18, 151, 223, 0.1);
		color: var(--blue-dark);
	}

	.header-cta {
		min-height: 42px;
		padding-inline: 16px;
		white-space: nowrap;
	}

	@media (max-width: 920px) {
		.header-inner {
			grid-template-columns: auto auto;
			justify-content: space-between;
		}

		.nav {
			display: none;
		}
	}

	@media (max-width: 580px) {
		.header-inner {
			min-height: 74px;
			gap: 12px;
		}

		.brand img {
			width: 112px;
		}

		.header-actions {
			gap: 8px;
		}

		.header-cta {
			display: none;
		}
	}
</style>
