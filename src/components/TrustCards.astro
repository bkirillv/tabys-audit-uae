---
import MaterialIcon from './MaterialIcon.astro';

interface Card {
	title: string;
	text: string;
	icon: string;
}

interface Props {
	items: Card[];
}

const { items } = Astro.props;
---

<div class="trust-band">
	<div class="container trust-grid">
		{
			items.map((item) => (
				<article class="trust-card">
					<div class="icon-box" aria-hidden="true">
						<MaterialIcon name={item.icon} />
					</div>
					<h2>{item.title}</h2>
					<p>{item.text}</p>
				</article>
			))
		}
	</div>
</div>

<style>
	.trust-band {
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		background: #ffffff;
		height: var(--trust-band-height);
		padding: 0;
	}

	.trust-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0;
		height: 100%;
	}

	.trust-card {
		border-right: 1px solid var(--line);
		background: #ffffff;
		padding: 16px 22px;
		text-align: center;
		overflow: hidden;
	}

	.trust-card:last-child {
		border-right: 0;
	}

	.icon-box {
		margin: 0 auto;
		background: transparent;
		color: var(--blue);
		width: 30px;
		height: 30px;
	}

	h2 {
		margin: 8px 0 5px;
		font-size: 0.9rem;
		line-height: 1.18;
	}

	p {
		margin: 0;
		color: var(--muted);
		font-size: 0.8rem;
		line-height: 1.34;
	}

	@media (max-width: 900px) {
		.trust-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			height: auto;
		}

		.trust-band {
			height: auto;
		}

		.trust-card:nth-child(2) {
			border-right: 0;
		}
	}

	@media (max-width: 560px) {
		.trust-grid {
			grid-template-columns: 1fr;
		}

		.trust-card {
			min-height: auto;
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}

		.trust-card:last-child {
			border-bottom: 0;
		}
	}
</style>
