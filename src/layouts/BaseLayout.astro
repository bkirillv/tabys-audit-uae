---
import { locales, type Locale } from '../i18n';
import { withBase } from '../site';

interface Props {
	lang: Locale;
	title: string;
	description: string;
	keywords: string;
	contact: {
		phone: string;
		email: string;
		address: string;
	};
	common: {
		brandName: string;
		logoAlt: string;
		schemaAreaServed: string;
		schemaAvailableLanguages: string[];
		schemaServiceTypes: string[];
	};
}

const { lang, title, description, keywords, contact, common } = Astro.props;
const siteUrl = Astro.site ?? new URL('https://tabys.consulting');
const canonicalUrl = new URL(withBase(`${lang}/`), siteUrl);
const imageUrl = new URL(withBase('tabys-logo-wide.png'), siteUrl);
const cleanPhone = contact.phone.replace(/\D/g, '');
const phoneHref = cleanPhone ? `+${cleanPhone}` : contact.phone;
const ogLocale: Record<Locale, string> = {
	en: 'en_US',
	ru: 'ru_RU',
};
const alternateLocales = locales.filter((locale) => locale !== lang);
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': ['Organization', 'AccountingService', 'ProfessionalService'],
			'@id': new URL(withBase('#organization'), siteUrl).toString(),
			name: common.brandName,
			url: siteUrl.toString(),
			logo: imageUrl.toString(),
			image: imageUrl.toString(),
			description,
			email: contact.email,
			telephone: phoneHref,
			priceRange: '$$',
			address: {
				'@type': 'PostalAddress',
				addressLocality: lang === 'ru' ? 'Дубай' : 'Dubai',
				addressCountry: 'AE',
				streetAddress: contact.address,
			},
			contactPoint: {
				'@type': 'ContactPoint',
				telephone: phoneHref,
				email: contact.email,
				contactType: lang === 'ru' ? 'Консультация по бухгалтерским услугам' : 'Accounting services consultation',
				areaServed: 'AE',
				availableLanguage: common.schemaAvailableLanguages,
			},
			areaServed: [
				{ '@type': 'City', name: lang === 'ru' ? 'Дубай' : 'Dubai' },
				{ '@type': 'Country', name: common.schemaAreaServed },
				{ '@type': 'AdministrativeArea', name: lang === 'ru' ? 'ОАЭ' : 'United Arab Emirates' },
			],
			availableLanguage: common.schemaAvailableLanguages,
			serviceType: common.schemaServiceTypes,
			knowsAbout: keywords.split(',').map((keyword) => keyword.trim()).filter(Boolean),
			hasOfferCatalog: {
				'@type': 'OfferCatalog',
				name: lang === 'ru' ? 'Бухгалтерские услуги TABYS' : 'TABYS accounting services',
				itemListElement: common.schemaServiceTypes.map((service) => ({
					'@type': 'Offer',
					itemOffered: {
						'@type': 'Service',
						name: service,
						areaServed: common.schemaAreaServed,
						provider: { '@id': new URL(withBase('#organization'), siteUrl).toString() },
					},
				})),
			},
		},
		{
			'@type': 'WebSite',
			'@id': new URL(withBase('#website'), siteUrl).toString(),
			name: common.brandName,
			url: siteUrl.toString(),
			inLanguage: lang,
			publisher: { '@id': new URL(withBase('#organization'), siteUrl).toString() },
		},
		{
			'@type': 'WebPage',
			'@id': canonicalUrl.toString(),
			url: canonicalUrl.toString(),
			name: title,
			description,
			isPartOf: { '@id': new URL(withBase('#website'), siteUrl).toString() },
			about: { '@id': new URL(withBase('#organization'), siteUrl).toString() },
			primaryImageOfPage: imageUrl.toString(),
			inLanguage: lang,
		},
		{
			'@type': 'BreadcrumbList',
			'@id': new URL(withBase(`${lang}/#breadcrumb`), siteUrl).toString(),
			itemListElement: [
				{
					'@type': 'ListItem',
					position: 1,
					name: common.brandName,
					item: canonicalUrl.toString(),
				},
			],
		},
	],
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
		<meta name="author" content={common.brandName} />
		<meta name="publisher" content={common.brandName} />
		<meta name="application-name" content={common.brandName} />
		<meta name="format-detection" content="telephone=yes" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<meta name="geo.region" content="AE-DU" />
		<meta name="geo.placename" content={lang === 'ru' ? 'Дубай, ОАЭ' : 'Dubai, United Arab Emirates'} />
		<meta name="geo.position" content="25.2048;55.2708" />
		<meta name="ICBM" content="25.2048, 55.2708" />
		<meta name="theme-color" content="#1297df" />
		<link rel="canonical" href={canonicalUrl.toString()} />
		{
			locales.map((locale) => (
				<link rel="alternate" hreflang={locale} href={new URL(withBase(`${locale}/`), siteUrl).toString()} />
			))
		}
		<link rel="alternate" hreflang="x-default" href={new URL(withBase('en/'), siteUrl).toString()} />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<link rel="icon" type="image/png" sizes="32x32" href={withBase('favicon.ico')} />
		<link rel="apple-touch-icon" sizes="180x180" href={withBase('apple-touch-icon.png')} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={common.brandName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl.toString()} />
		<meta property="og:image" content={imageUrl.toString()} />
		<meta property="og:image:alt" content={common.logoAlt} />
		<meta property="og:image:width" content="1080" />
		<meta property="og:image:height" content="540" />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:locale" content={ogLocale[lang]} />
		{alternateLocales.map((locale) => <meta property="og:locale:alternate" content={ogLocale[locale]} />)}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl.toString()} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--ink: #071a36;
		--muted: #5d6b80;
		--line: #dceaf6;
		--paper: #ffffff;
		--soft: #f3f9fe;
		--blue: #1297df;
		--blue-dark: #0479c6;
		--cyan: #1fbde4;
		--orange: #ff7a13;
		--navy: #021a33;
		--shadow: 0 18px 50px rgba(4, 121, 198, 0.13);
		--header-height: 82px;
		--trust-band-height: 160px;
		color-scheme: light;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: var(--paper);
		color: var(--ink);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: var(--header-height);
	}

	body {
		margin: 0;
		min-width: 320px;
		background:
			radial-gradient(circle at 86% 12%, rgba(31, 189, 228, 0.14), transparent 28rem),
			linear-gradient(180deg, #ffffff 0%, #f7fbff 58%, #ffffff 100%);
	}

	body,
	button,
	input,
	textarea {
		font: inherit;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.container {
		width: min(1160px, calc(100% - 40px));
		margin: 0 auto;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: var(--blue-dark);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.section-title {
		margin: 0;
		color: var(--ink);
		font-size: clamp(2rem, 4vw, 3.1rem);
		line-height: 1.05;
		letter-spacing: 0;
	}

	.section-copy {
		color: var(--muted);
		line-height: 1.7;
	}

	.button {
		display: inline-flex;
		min-height: 48px;
		align-items: center;
		justify-content: center;
		gap: 10px;
		border: 1px solid transparent;
		border-radius: 8px;
		padding: 0 20px;
		font-weight: 800;
		cursor: pointer;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button:focus-visible,
	a:focus-visible {
		outline: 3px solid rgba(255, 122, 19, 0.4);
		outline-offset: 3px;
	}

	.button-primary {
		background: var(--blue);
		color: #ffffff;
		box-shadow: 0 14px 30px rgba(18, 151, 223, 0.28);
	}

	.button-primary:hover {
		background: var(--blue-dark);
	}

	.button-secondary {
		border-color: rgba(18, 151, 223, 0.24);
		background: #ffffff;
		color: var(--blue-dark);
	}

	.button-secondary:hover {
		border-color: rgba(255, 122, 19, 0.5);
		color: var(--orange);
	}

	.icon-box {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		border-radius: 8px;
		background: linear-gradient(135deg, rgba(31, 189, 228, 0.14), rgba(255, 122, 19, 0.12));
		color: var(--blue-dark);
	}

	@media (max-width: 760px) {
		:root {
			--header-height: 74px;
			--trust-band-height: auto;
		}

		html {
			scroll-padding-top: var(--header-height);
		}

		.container {
			width: min(100% - 28px, 1160px);
		}

		.button {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			scroll-behavior: auto !important;
			transition-duration: 0.01ms !important;
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
		}
	}
</style>
