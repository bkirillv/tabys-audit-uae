---
import { ui } from '../i18n';
import { withBase } from '../site';

const englishTarget = withBase('en/');
const russianTarget = withBase('ru/');
const redirect = ui.en.redirect;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={englishTarget} />
		<title>{redirect.title}</title>
		<script is:inline define:vars={{ englishTarget, russianTarget }}>
			const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
			const hasRussian = languages.some((language) => language.toLowerCase().startsWith('ru'));
			const target = hasRussian ? russianTarget : englishTarget;
			const nextUrl = new URL(target, window.location.origin);
			nextUrl.search = window.location.search;
			nextUrl.hash = window.location.hash;
			window.location.replace(nextUrl);
		</script>
	</head>
	<body>
		<p>{redirect.chooseLanguage}</p>
		<a href={englishTarget}>{redirect.englishLink}</a>
		<a href={russianTarget}>{ui.ru.redirect.russianLink}</a>
	</body>
</html>
